# PostgreSQL — copie para .env e preencha os valores reais
# cp .env.example .env

# URL única (Prisma, Drizzle, node-pg, etc.)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require

# API local (opcional; padrão 3001). Em Render usa-se PORT — o servidor aceita PORT ou API_PORT.
# API_PORT=3001

# Base de dados partilhada: menos ligações simultâneas ao pool pg (1–50; omisso = 5)
# PG_POOL_MAX=2

# Resposta em memória na API (vários browsers / polling = 1 query ao PG por TTL)
# 0 = desliga cache. Omisso: serviços 120s, runs 60s
# API_CACHE_SERVICES_MS=120000
# API_CACHE_RUNS_MS=60000

# Ambiente (opcional)
# NODE_ENV=development

# --- Render.com: UM Web Service (API + site Whacked na mesma URL) ---
# Root Directory: vazio (raiz do repo). Há package.json na raiz que faz build do front + deps da API.
# Build Command: npm install && npm run build
# Start Command: npm start
# Env: DATABASE_URL (obrigatório). Não precisas de VITE_API_BASE_URL — o browser usa /api na mesma origem.
# Vários domínios no MESMO Web Service: o servidor escolhe o build pelo Host (por defeito whacked.work / cornfield.work).
# WHACKED_HOSTS=www.whacked.work,whacked.work
# CORNFIELD_HOSTS=www.cornfield.work,cornfield.work
# Atrás de proxy (Render): TRUST_PROXY_HOPS=1 (padrão). Um único dist forçado: SERVE_STATIC_FROM=whacked_front/dist

# Front (whacked_front/.env ou cornfield_front/.env — Vite só lê na pasta do build)
# Em produção no Render (site estático separado da API), define a URL pública do Web Service da API:
# VITE_API_BASE_URL=https://teu-servico-api.onrender.com
# (sem barra no fim; em dev deixes vazio para usar o proxy /api → localhost:3001)
# Menos pedidos à API (e à BD): polling em ms (omisso: catálogo 300000, agenda 180000). 0 = só ao abrir a página
# VITE_REFETCH_SERVICES_MS=300000
# VITE_REFETCH_RUNS_MS=180000
# Se a API falhar, mostrar o catálogo estático antigo em vez de só erro:
# VITE_USE_STATIC_FALLBACK=true

# Agrupamento por id_service_category (API server/)
# JOIN opcional para o nome da categoria:
# SERVICE_CATEGORY_TABLE=service_categories
# SERVICE_CATEGORY_ID_COLUMN=id
# SERVICE_CATEGORY_NAME_COLUMN=name
# SERVICE_CATEGORY_FK_COLUMN=id_service_category
# Sem tabela de nomes (só FK): desliga o JOIN e usa "Category {id}"
# SERVICE_CATEGORY_JOIN=false

# Agenda — tabela runs (GET /api/runs?startDate=&endDate=)
# Colunas runs (referência): id, max_buyers, actual_pot, locked, actual_pot_dolar,
#   min_price_enabled, min_price_gold, min_price_dollar, team, time, quantity_boss,
#   date, difficulty, loot, name, note, raid, run_type
# Colunas buyers (referência): id, id_run, status, buyer_pot, is_paid, …
# RUNS_TABLE=runs
# RUNS_DATE_COLUMN=date
# RUNS_TIME_COLUMN=time
# Chave na tabela runs usada no JOIN (quase sempre id). NÃO uses id_run — isso é coluna de buyers.
# RUNS_PK_COLUMN=id
# RUNS_MAX_BUYERS_COLUMN=max_buyers
# Slots na API = max(0, max_buyers − COUNT(buyers do run que NÃO estão cancelados).
# Padrão: conta todas as linhas em buyers com mesmo id_run, exceto status cancelled ou noshow (lista configurável).
# BUYERS_TABLE=buyers
# BUYERS_RUN_FK_COLUMN=id_run
# BUYERS_STATE_COLUMN=status
# BUYERS_CANCELLED_VALUES=cancelled,noshow
# Contar só is_paid = true (modo antigo): BUYERS_COUNT_MODE=is_paid
# BUYERS_ACTIVE_COLUMN=is_paid
# BUYERS_ACTIVE_VARCHAR=true
# BUYERS_ACTIVE_NUMERIC=true
# Legado: BUYERS_STATUS_COLUMN usado como fallback do nome da coluna de estado
# Desliga contagem em buyers (útil sem tabela ou em migração):
# RUNS_SKIP_BUYERS_SLOT_COUNT=true
# Coluna opcional que, se preenchida, força o valor de slots (ignora fórmula):
# RUNS_SLOTS_COLUMN=
# Sem max_buyers na linha, a API ainda pode ler slot_available / slots_available se existirem.
# RUNS_RAID_COLUMN=raid
# RUNS_DIFFICULTY_COLUMN=difficulty
# RUNS_TEAM_COLUMN=team
# RUNS_NAME_COLUMN=name
# RUNS_LOOT_COLUMN=loot
# Opcional: após o horário do run (fuso abaixo), forçar slots = 0 na API (desliga o padrão; era confundir com max−buyers).
# RUNS_ZERO_SLOTS_WHEN_PAST=true
# RUNS_SCHEDULE_TIMEZONE=America/New_York
